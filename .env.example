# LLM backend switch — "redpill" (default, Phala TEE), "nearai" (alternate
# TEE), or "ollama" (local dev).
# Flip with:   python -m transcripts.cli llm use redpill|nearai|ollama
# Inspect:     python -m transcripts.cli llm status
CONCLAVE_LLM_BACKEND=redpill

# RedPill (Phala) — TEE-served, OpenAI-compatible. Default production backend.
# Sign up at https://redpill.ai to get an API key.
CONCLAVE_REDPILL_API_KEY=
CONCLAVE_REDPILL_MODEL=google/gemma-3-27b-it
# CONCLAVE_REDPILL_BASE_URL=https://api.redpill.ai/v1

# NearAI API — alternate TEE backend (kept for compatibility with @pytest.mark.live)
CONCLAVE_NEARAI_API_KEY=
CONCLAVE_DEFAULT_MODEL=deepseek-ai/DeepSeek-V3.1

# Ollama (local dev) — only consulted when CONCLAVE_LLM_BACKEND=ollama.
# Default model is the Conclave-tuned qwen2.5-7b variant (num_ctx=8192).
# One-time setup:
#   ollama pull qwen2.5:7b-instruct
#   ollama create qwen2.5-conclave -f ollama/Modelfile.qwen-conclave
# CONCLAVE_OLLAMA_MODEL=qwen2.5-conclave
# CONCLAVE_OLLAMA_BASE_URL=http://localhost:11434/v1

# Supabase auth — Project Settings → API in your Supabase dashboard
# JWT validation uses JWKS (ES256/ECC P-256) — no shared secret needed
CONCLAVE_SUPABASE_URL=https://<your-project-ref>.supabase.co
CONCLAVE_SUPABASE_ANON_KEY=

# Google Calendar integration (optional — added with the transcript-saving merge).
# When client id/secret/redirect are unset, all /api/calendar/* routes return 503
# and the auto-record poller is a no-op; the rest of the app runs fine.
# This is a DEDICATED Google OAuth client (not the Supabase Google login) so we can
# request Calendar scopes + offline access and hold a refresh token for background
# bot dispatch. Create it in Google Cloud Console → APIs & Services → Credentials.
CONCLAVE_GOOGLE_CLIENT_ID=
CONCLAVE_GOOGLE_CLIENT_SECRET=
# Must exactly match an Authorized redirect URI in the Google console; points at
# GET /api/calendar/callback  (e.g. https://<your-host>/api/calendar/callback).
CONCLAVE_GOOGLE_REDIRECT_URI=
# Fernet key encrypting Google OAuth tokens at rest (google_oauth_tokens table).
# REQUIRED to use Calendar — the token store refuses to persist tokens without it
# (operator-blind invariant). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONCLAVE_TOKEN_ENC_KEY=
# Optional calendar tuning (sensible defaults if unset):
# CONCLAVE_CALENDAR_POLL_SECONDS=60      # auto-record poller interval
# CONCLAVE_CALENDAR_POST_CONNECT_URL=    # redirect target after a user connects
# CONCLAVE_DISABLE_SCHEDULER=            # truthy → disable the background poller

# Recato bot dispatch (optional) — used by calendar auto-record to launch a Recato
# bot for a scheduled meeting and receive its completion webhook. Plain env vars,
# no CONCLAVE_ prefix. Needed only for the calendar→auto-record path.
RECATO_API_BASE_URL=
RECATO_API_TOKEN=
RECATO_MEETING_COMPLETED_URL=
RECATO_WEBHOOK_SECRET=

# LangSmith tracing (optional)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=conclave-eval

# Per-skill model config lives in skills/<skill-name>/.env
# See skills/hackathon_novelty/.env.example for an example
