# LLM backend switch — "redpill" (default, Phala TEE), "nearai" (alternate
# TEE), or "ollama" (local dev).
# Flip with:   python -m transcripts.cli llm use redpill|nearai|ollama
# Inspect:     python -m transcripts.cli llm status
CONCLAVE_LLM_BACKEND=redpill

# RedPill (Phala) — TEE-served, OpenAI-compatible. Default production backend.
# Sign up at https://redpill.ai to get an API key.
CONCLAVE_REDPILL_API_KEY=
CONCLAVE_REDPILL_MODEL=google/gemma-3-27b-it
# CONCLAVE_REDPILL_BASE_URL=https://api.redpill.ai/v1

# NearAI API — alternate TEE backend (kept for compatibility with @pytest.mark.live)
CONCLAVE_NEARAI_API_KEY=
CONCLAVE_DEFAULT_MODEL=deepseek-ai/DeepSeek-V3.1

# Ollama (local dev) — only consulted when CONCLAVE_LLM_BACKEND=ollama.
# Default model is the Conclave-tuned qwen2.5-7b variant (num_ctx=8192).
# One-time setup:
#   ollama pull qwen2.5:7b-instruct
#   ollama create qwen2.5-conclave -f ollama/Modelfile.qwen-conclave
# CONCLAVE_OLLAMA_MODEL=qwen2.5-conclave
# CONCLAVE_OLLAMA_BASE_URL=http://localhost:11434/v1

# Supabase auth — Project Settings → API in your Supabase dashboard
# JWT validation uses JWKS (ES256/ECC P-256) — no shared secret needed
CONCLAVE_SUPABASE_URL=https://<your-project-ref>.supabase.co
CONCLAVE_SUPABASE_ANON_KEY=

# LangSmith tracing (optional)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=conclave-eval

# Per-skill model config lives in skills/<skill-name>/.env
# See skills/hackathon_novelty/.env.example for an example
