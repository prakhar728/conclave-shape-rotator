# Phase 3.5.0 C3+: scripts/ stays ignored by default but eval-harness
# CLIs are real artifacts. Negation needs the dir-then-contents dance:
# a bare "scripts/" would stop git from descending at all.
!scripts/
scripts/*
!scripts/eval_extraction_bakeoff.py
!scripts/chunk_and_embed_existing.py
!scripts/eval_search_quality.py
!scripts/seed_demo.py
# Persistent eval harness (Phase 0/1): connective layer + dataset translators
# + scorers are real, maintained artifacts. Dir-then-contents negation.
!scripts/eval/
!scripts/eval/*.py
scripts/eval/__pycache__/
!alembic/scripts/
tests/fixtures/*
!tests/fixtures/interview_reflection/
!tests/fixtures/voxterm_session.json
# Phase 3.5.0: track ground-truth yamls (the contract for C3/C13/C24)
# and reference .md docs (CONVENTIONS, etc.); the transcripts they cite
# stay ignored — share locally / via non-git path.
!tests/fixtures/transcripts/
tests/fixtures/transcripts/*
!tests/fixtures/transcripts/*.expected.yaml
!tests/fixtures/transcripts/*.md
.agents/
skills-lock.json
data/*.db
data/*.db-*
data/mock_ideas/submissions.jsonl
external/

# Local-only enrichment artefacts (cohort transcript content + derived).
# Regenerable via `transcripts.cli enrich --pending`; cohort transcripts
# themselves are already gitignored under tests/fixtures/.
# Glob covers run variants (enriched-output-gemma3/, -12k/) and the
# comparison markdowns (enriched-output*-comparison.md).
enriched-output*/
enriched-output*.md
tmp/

# Backup files created by sed -i.bak edits (may contain old .env secrets)
.env.bak
.env.*.bak
*.env.bak

# macOS metadata
.DS_Store
**/.DS_Store

# eval datasets: downloaded benchmarks + generated eval DBs (code is tracked, data is not)
datasets/qmsum/
datasets/ami/
datasets/*.db
